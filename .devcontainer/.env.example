# Copy this file to `.env` and fill in your secrets.
#   cp .devcontainer/.env.example .devcontainer/.env
#
# The real `.env` is gitignored and never committed. It is loaded into the
# container via --env-file (see start.sh and devcontainer.json).

# GitHub personal access token (scopes: repo, read:org, workflow).
# Used by the `gh` CLI and for git push over HTTPS.
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
