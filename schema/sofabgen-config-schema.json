{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "https://github.com/sofa-buffers/generator/schema/sofabgen-config-schema.json",
  "title": "SofaBuffers Generator Config Schema",
  "description": "Validates sofabgen configuration files (YAML or JSON). PLAN \u00a77. Every level is closed (additionalProperties:false) so typos are rejected, not ignored.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "generic": {
      "$ref": "#/$defs/generic"
    },
    "targets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "c": {
          "$ref": "#/$defs/target_c"
        },
        "cpp": {
          "$ref": "#/$defs/target_cpp"
        },
        "rust": {
          "$ref": "#/$defs/target_rust"
        },
        "go": {
          "$ref": "#/$defs/target_go"
        },
        "python": {
          "$ref": "#/$defs/target_python"
        },
        "java": {
          "$ref": "#/$defs/target_java"
        },
        "csharp": {
          "$ref": "#/$defs/target_csharp"
        },
        "typescript": {
          "$ref": "#/$defs/target_typescript"
        }
      }
    }
  },
  "$defs": {
    "buffer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "stack",
            "heap"
          ]
        },
        "size": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "enum": [
                "auto"
              ]
            }
          ]
        }
      }
    },
    "generic": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "namespace": {
          "type": "string"
        },
        "emit": {
          "type": "string",
          "enum": [
            "sources",
            "project"
          ]
        },
        "input_dir": {
          "type": "string"
        },
        "output_dir": {
          "type": "string"
        },
        "timestamp": {
          "type": "boolean"
        },
        "timestamp_format": {
          "type": "string"
        },
        "tool_banner": {
          "type": "string"
        },
        "license": {
          "type": "string"
        },
        "emit_deprecated": {
          "type": "boolean"
        },
        "validation": {
          "type": "string",
          "enum": [
            "debug",
            "always",
            "off"
          ]
        },
        "naming": {
          "type": "string"
        },
        "file_layout": {
          "type": "string",
          "enum": [
            "one_file",
            "file_per_message"
          ]
        }
      }
    },
    "common_target": {
      "namespace": {
        "type": "string"
      },
      "emit": {
        "type": "string",
        "enum": [
          "sources",
          "project"
        ]
      },
      "validation": {
        "type": "string",
        "enum": [
          "debug",
          "always",
          "off"
        ]
      },
      "naming": {
        "type": "string"
      },
      "file_layout": {
        "type": "string",
        "enum": [
          "one_file",
          "file_per_message"
        ]
      },
      "buffer": {
        "$ref": "#/$defs/buffer"
      }
    },
    "target_c": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "namespace": {
          "type": "string"
        },
        "emit": {
          "type": "string",
          "enum": [
            "sources",
            "project"
          ]
        },
        "validation": {
          "type": "string",
          "enum": [
            "debug",
            "always",
            "off"
          ]
        },
        "naming": {
          "type": "string"
        },
        "file_layout": {
          "type": "string",
          "enum": [
            "one_file",
            "file_per_message"
          ]
        },
        "buffer": {
          "$ref": "#/$defs/buffer"
        },
        "symbol_prefix": {
          "type": "string"
        },
        "c_standard": {
          "type": "string",
          "enum": [
            "c99",
            "c11"
          ]
        },
        "header_extension": {
          "type": "string"
        },
        "source_extension": {
          "type": "string"
        },
        "include_guard": {
          "type": "string",
          "enum": [
            "ifndef",
            "pragma_once"
          ]
        },
        "descriptor_profile": {
          "type": "string",
          "enum": [
            "auto",
            "small",
            "medium",
            "big"
          ]
        },
        "string_storage": {
          "type": "string",
          "enum": [
            "fixed_inline",
            "caller_buffer"
          ]
        }
      }
    },
    "target_cpp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "namespace": {
          "type": "string"
        },
        "corelib": {
          "type": "string",
          "enum": [
            "cpp",
            "c-cpp"
          ],
          "default": "cpp"
        },
        "allow_dynamic": {
          "type": "boolean",
          "description": "corelib: c-cpp only. Keep a std::vector/std::string heap fallback for genuinely unbounded fields (string/blob without maxlen, array without count) instead of failing generation; bounded fields still use fixed-capacity inline storage."
        },
        "emit": {
          "type": "string",
          "enum": [
            "sources",
            "project"
          ]
        },
        "validation": {
          "type": "string",
          "enum": [
            "debug",
            "always",
            "off"
          ]
        },
        "naming": {
          "type": "string"
        },
        "file_layout": {
          "type": "string",
          "enum": [
            "one_file",
            "file_per_message"
          ]
        },
        "buffer": {
          "$ref": "#/$defs/buffer"
        },
        "cpp_standard": {
          "type": "string",
          "enum": [
            "c++20",
            "c++23"
          ]
        },
        "header_only": {
          "type": "boolean"
        },
        "max_size_strategy": {
          "type": "string",
          "enum": [
            "upper_bound"
          ]
        },
        "zero_copy_strings": {
          "type": "boolean"
        }
      }
    },
    "target_rust": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "corelib": {
          "type": "string",
          "enum": [
            "rs-no-std",
            "rs"
          ],
          "default": "rs"
        },
        "emit": {
          "type": "string",
          "enum": [
            "sources",
            "project"
          ]
        },
        "validation": {
          "type": "string",
          "enum": [
            "debug",
            "always",
            "off"
          ]
        },
        "naming": {
          "type": "string"
        },
        "file_layout": {
          "type": "string",
          "enum": [
            "one_file",
            "file_per_message"
          ]
        },
        "buffer": {
          "$ref": "#/$defs/buffer"
        },
        "module": {
          "type": "string"
        },
        "edition": {
          "type": "string",
          "enum": [
            "2021",
            "2024"
          ]
        },
        "no_std": {
          "type": "boolean",
          "description": "rust corelib: rs-no-std only. Emit a genuinely #![no_std], heap-free crate: heapless::String<N>/Vec<T,N> fixed-capacity fields sized from the schema, a bounded decode stack, and serde gated behind a cargo feature. On by default for corelib: rs-no-std; set false to emit an ordinary std crate against the no-std corelib."
        },
        "alloc": {
          "type": "boolean"
        },
        "allow_dynamic": {
          "type": "boolean",
          "description": "rust no_std only. Keep an alloc::String/alloc::Vec heap fallback for genuinely unbounded fields (string/blob without maxlen, array without count) instead of failing generation; bounded fields still use fixed-capacity heapless storage. The Rust analog of the c-cpp allow_dynamic."
        },
        "string_storage": {
          "type": "string",
          "enum": [
            "fixed",
            "heapless",
            "alloc_string"
          ]
        },
        "derives": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "target_go": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "emit": {
          "type": "string",
          "enum": [
            "sources",
            "project"
          ]
        },
        "validation": {
          "type": "string",
          "enum": [
            "debug",
            "always",
            "off"
          ]
        },
        "naming": {
          "type": "string"
        },
        "file_layout": {
          "type": "string",
          "enum": [
            "one_file",
            "file_per_message"
          ]
        },
        "buffer": {
          "$ref": "#/$defs/buffer"
        },
        "package": {
          "type": "string"
        },
        "module_path": {
          "type": "string"
        },
        "go_version": {
          "type": "string"
        },
        "decode_style": {
          "type": "string",
          "enum": [
            "pull",
            "visitor"
          ]
        },
        "accessors": {
          "type": "string",
          "enum": [
            "fields",
            "getters"
          ]
        }
      }
    },
    "target_python": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "emit": {
          "type": "string",
          "enum": [
            "sources",
            "project"
          ]
        },
        "validation": {
          "type": "string",
          "enum": [
            "debug",
            "always",
            "off"
          ]
        },
        "naming": {
          "type": "string"
        },
        "file_layout": {
          "type": "string",
          "enum": [
            "one_file",
            "file_per_message"
          ]
        },
        "buffer": {
          "$ref": "#/$defs/buffer"
        },
        "package": {
          "type": "string"
        },
        "python_min": {
          "type": "string"
        },
        "class_style": {
          "type": "string",
          "enum": [
            "dataclass",
            "slots_dataclass",
            "plain"
          ]
        },
        "frozen": {
          "type": "boolean"
        },
        "type_hints": {
          "type": "boolean"
        },
        "decode_style": {
          "type": "string",
          "enum": [
            "pull",
            "visitor"
          ]
        }
      }
    },
    "target_java": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "emit": {
          "type": "string",
          "enum": [
            "sources",
            "project"
          ]
        },
        "validation": {
          "type": "string",
          "enum": [
            "debug",
            "always",
            "off"
          ]
        },
        "naming": {
          "type": "string"
        },
        "file_layout": {
          "type": "string",
          "enum": [
            "one_file",
            "file_per_message"
          ]
        },
        "buffer": {
          "$ref": "#/$defs/buffer"
        },
        "package": {
          "type": "string"
        },
        "java_version": {
          "type": "integer"
        },
        "use_records": {
          "type": "boolean"
        },
        "build": {
          "type": "string",
          "enum": [
            "maven",
            "gradle"
          ]
        },
        "group_id": {
          "type": "string"
        },
        "artifact_id": {
          "type": "string"
        }
      }
    },
    "target_csharp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "emit": {
          "type": "string",
          "enum": [
            "sources",
            "project"
          ]
        },
        "validation": {
          "type": "string",
          "enum": [
            "debug",
            "always",
            "off"
          ]
        },
        "naming": {
          "type": "string"
        },
        "file_layout": {
          "type": "string",
          "enum": [
            "one_file",
            "file_per_message"
          ]
        },
        "buffer": {
          "$ref": "#/$defs/buffer"
        },
        "namespace": {
          "type": "string"
        },
        "target_framework": {
          "type": "string"
        },
        "nullable": {
          "type": "string",
          "enum": [
            "enable",
            "disable"
          ]
        },
        "lang_version": {
          "type": "string"
        },
        "use_records": {
          "type": "boolean"
        },
        "generate_doc_file": {
          "type": "boolean"
        }
      }
    },
    "target_typescript": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "emit": {
          "type": "string",
          "enum": [
            "sources",
            "project"
          ]
        },
        "validation": {
          "type": "string",
          "enum": [
            "debug",
            "always",
            "off"
          ]
        },
        "naming": {
          "type": "string"
        },
        "file_layout": {
          "type": "string",
          "enum": [
            "one_file",
            "file_per_message"
          ]
        },
        "buffer": {
          "$ref": "#/$defs/buffer"
        },
        "module": {
          "type": "string",
          "enum": [
            "esm",
            "cjs",
            "dual"
          ]
        },
        "package_name": {
          "type": "string"
        },
        "ts_target": {
          "type": "string"
        },
        "node_min": {
          "type": "string"
        },
        "int64": {
          "type": "string",
          "enum": [
            "bigint",
            "long",
            "number"
          ],
          "default": "bigint",
          "description": "64-bit field representation. bigint (default): bigint scalars and bigint[] arrays. long: u64[]/i64[] backed by corelib Long[] behind a get/set accessor pair (bigint-free encode/decode hot path; assignment accepts Long | bigint | number); scalars stay bigint. number: additionally maps u64/i64 scalars to number - the caller guarantees scalar values fit the +/-2^53 safe-integer range. All modes are wire-identical."
        },
        "emit_dts": {
          "type": "boolean"
        },
        "decode_style": {
          "type": "string",
          "enum": [
            "visitor"
          ]
        }
      }
    }
  }
}
