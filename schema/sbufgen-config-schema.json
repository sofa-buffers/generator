{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "https://github.com/sofa-buffers/generator/schema/sbufgen-config-schema.json",
  "title": "SofaBuffers Generator Config Schema",
  "description": "Validates sbufgen configuration files (YAML or JSON). PLAN \u00a77. Every level is closed (additionalProperties:false) so typos are rejected, not ignored.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "generic": {
      "$ref": "#/$defs/generic"
    },
    "targets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "c": {
          "$ref": "#/$defs/target_c"
        },
        "cpp-embedded": {
          "$ref": "#/$defs/target_cpp_embedded"
        },
        "cpp": {
          "$ref": "#/$defs/target_cpp"
        },
        "rust": {
          "$ref": "#/$defs/target_rust"
        },
        "go": {
          "$ref": "#/$defs/target_go"
        },
        "python": {
          "$ref": "#/$defs/target_python"
        },
        "java": {
          "$ref": "#/$defs/target_java"
        },
        "csharp": {
          "$ref": "#/$defs/target_csharp"
        },
        "typescript": {
          "$ref": "#/$defs/target_typescript"
        }
      }
    }
  },
  "$defs": {
    "buffer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "stack",
            "heap"
          ]
        },
        "size": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "enum": [
                "auto"
              ]
            }
          ]
        }
      }
    },
    "generic": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "namespace": {
          "type": "string"
        },
        "emit": {
          "type": "string",
          "enum": [
            "sources",
            "project"
          ]
        },
        "input_dir": {
          "type": "string"
        },
        "output_dir": {
          "type": "string"
        },
        "timestamp": {
          "type": "boolean"
        },
        "timestamp_format": {
          "type": "string"
        },
        "tool_banner": {
          "type": "string"
        },
        "license": {
          "type": "string"
        },
        "emit_deprecated": {
          "type": "boolean"
        },
        "validation": {
          "type": "string",
          "enum": [
            "debug",
            "always",
            "off"
          ]
        },
        "naming": {
          "type": "string"
        },
        "file_layout": {
          "type": "string",
          "enum": [
            "one_file",
            "file_per_message"
          ]
        },
        "omit_defaults": {
          "type": "boolean",
          "description": "Omit fields equal to their default from the serialized stream (protobuf-style). Decode reconstructs them from the same defaults."
        }
      }
    },
    "common_target": {
      "namespace": {
        "type": "string"
      },
      "emit": {
        "type": "string",
        "enum": [
          "sources",
          "project"
        ]
      },
      "validation": {
        "type": "string",
        "enum": [
          "debug",
          "always",
          "off"
        ]
      },
      "naming": {
        "type": "string"
      },
      "file_layout": {
        "type": "string",
        "enum": [
          "one_file",
          "file_per_message"
        ]
      },
      "buffer": {
        "$ref": "#/$defs/buffer"
      }
    },
    "target_c": {
      "type": "object",
      "additionalProperties": false,
