            "small",
            "medium",
            "big"
          ]
        },
        "string_storage": {
          "type": "string",
          "enum": [
            "fixed_inline",
            "caller_buffer"
          ]
        },
        "omit_defaults": {
          "type": "boolean"
        }
      }
    },
    "target_cpp_embedded": {
