{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "SofaBuffers Message Definition Schema v1",
  "description": "Validates message definition files for custom messages and payloads.",
  "type": "object",
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version number."
    },
    "$defs": {
      "type": "object",
      "description": "Defines reusable field schemas that can be referenced by messages or other definitions.",
      "properties": {
        "struct": {
          "type": "object",
          "patternProperties": {
            "^[A-Za-z][A-Za-z0-9_]*$": {
              "$ref": "#/$defs/struct"
            }
          },
          "additionalProperties": false
        },
        "union": {
          "type": "object",
          "patternProperties": {
            "^[A-Za-z][A-Za-z0-9_]*$": {
              "$ref": "#/$defs/union"
            }
          },
          "additionalProperties": false
        },
        "enum": {
          "type": "object",
          "patternProperties": {
            "^[A-Za-z][A-Za-z0-9_]*$": {
              "$ref": "#/$defs/enum"
            }
          },
          "additionalProperties": false
        },
        "bitfield": {
          "type": "object",
          "patternProperties": {
            "^[A-Za-z][A-Za-z0-9_]*$": {
              "$ref": "#/$defs/bitfield"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "messages": {
      "type": "object",
      "description": "Each key defines a message by its unique name and its schema.",
      "patternProperties": {
        "^[A-Za-z][A-Za-z0-9_]*$": {
          "type": "object",
          "properties": {
            "summary": {
              "type": "string",
              "description": "Description of the message."
            },
            "payload": {
              "type": "object",
              "description": "Defines all fields of this message.",
              "uniqueIds": true,
              "patternProperties": {
                "^[A-Za-z][A-Za-z0-9_]*$": {
                  "$ref": "#/$defs/field"
                }
              },
              "additionalProperties": false
            }
          },
          "required": ["payload"],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["version"],
  "anyOf": [
    { "required": ["$defs"] },
    { "required": ["messages"] }
  ],
  "additionalProperties": false,

  "$defs": {
    "types": {
      "id": {
        "type": "integer",
        "minimum": 0,
        "maximum": 2147483647,
        "description": "Unique numeric ID for the field within the parent message or struct."
      }
    },

    "arrayItems": {
      "type": "object",
      "description": "Constraints for array elements. Numeric primitives and string/blob are leaf elements (compact array wire types / a sequence of fixlen values); struct/union/array elements make this a nested array, lowered to a wrapper sequence of nested sequences. See MESSAGE_SPEC.",
      "properties": {
        "type": {
          "type": "string",
          "description": "Element type. Scalars and string/blob are leaf elements; struct/union/array nest further.",
          "enum": [
            "u8", "u16", "u32", "u64",
            "i8", "i16", "i32", "i64",
            "fp32", "fp64",
            "string", "blob",
            "struct", "union", "array",
            "enum", "boolean", "bitfield"
          ]
        },
        "count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2147483647,
          "description": "Capacity (maximum element count) of this array dimension. Optional, but required by targets that cannot allocate dynamically (so the buffer can be pre-sized). When present, the wire may carry 0 .. count elements; when omitted, the array is dynamic / unbounded. Never appears on the wire either way."
        },
        "maxlen": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2147483647,
          "description": "Maximum byte length of each string/blob element. Only valid when 'type' is string or blob."
        },
        "fields": {
          "description": "Field definitions when 'type' is struct.",
          "oneOf": [
            { "$ref": "#/$defs/struct" },
            {
              "type": "object",
              "properties": { "$ref": { "type": "string", "description": "Reference to a predefined struct in $defs." } },
              "required": ["$ref"],
              "additionalProperties": false
            }
          ]
        },
        "oneof": {
          "description": "Option definitions when 'type' is union.",
          "oneOf": [
            { "$ref": "#/$defs/union" },
            {
              "type": "object",
              "properties": { "$ref": { "type": "string", "description": "Reference to a predefined union in $defs." } },
              "required": ["$ref"],
              "additionalProperties": false
            }
          ]
        },
        "default_id": {
          "type": "integer", "minimum": 0, "maximum": 2147483647,
          "description": "Default option id when 'type' is union."
        },
        "items": {
          "$ref": "#/$defs/arrayItems",
          "description": "Inner element definition when 'type' is array (array of arrays)."
        },
        "enum": {
          "description": "Member definitions when 'type' is enum.",
          "oneOf": [
            { "$ref": "#/$defs/enum" },
            {
              "type": "object",
              "properties": { "$ref": { "type": "string", "description": "Reference to a predefined enum in $defs." } },
              "required": ["$ref"],
              "additionalProperties": false
            }
          ]
        },
        "bits": {
          "description": "Flag definitions when 'type' is bitfield.",
          "oneOf": [
            { "$ref": "#/$defs/bitfield" },
            {
              "type": "object",
              "properties": { "$ref": { "type": "string", "description": "Reference to a predefined bitfield in $defs." } },
              "required": ["$ref"],
              "additionalProperties": false
            }
          ]
        }
      },
      "required": ["type"],
      "additionalProperties": false,
      "allOf": [
        { "if": { "properties": { "type": { "const": "struct" } }, "required": ["type"] }, "then": { "required": ["fields"] } },
        { "if": { "properties": { "type": { "const": "union" } }, "required": ["type"] }, "then": { "required": ["oneof"] } },
        { "if": { "properties": { "type": { "const": "array" } }, "required": ["type"] }, "then": { "required": ["items"] } },
        { "if": { "required": ["maxlen"] }, "then": { "properties": { "type": { "enum": ["string", "blob"] } } } },
        { "if": { "required": ["fields"] }, "then": { "properties": { "type": { "const": "struct" } } } },
        { "if": { "required": ["oneof"] }, "then": { "properties": { "type": { "const": "union" } } } },
        { "if": { "required": ["default_id"] }, "then": { "properties": { "type": { "const": "union" } } } },
        { "if": { "required": ["items"] }, "then": { "properties": { "type": { "const": "array" } } } },
        { "if": { "properties": { "type": { "const": "enum" } }, "required": ["type"] }, "then": { "required": ["enum"] } },
        { "if": { "properties": { "type": { "const": "bitfield" } }, "required": ["type"] }, "then": { "required": ["bits"] } },
        { "if": { "required": ["enum"] }, "then": { "properties": { "type": { "const": "enum" } } } },
        { "if": { "required": ["bits"] }, "then": { "properties": { "type": { "const": "bitfield" } } } }
      ]
    },

    "enum": {
      "type": "object",
      "description": "Defines the allowed constants for enum type fields; keys are enum names.",
      "patternProperties": {
        "^[A-Za-z][A-Za-z0-9_]*$": {
          "description": "Defines a specific key name within the enum.",
          "anyOf": [
            {
              "type": "integer", "minimum": -2147483648, "maximum": 2147483647,
              "description": "Numeric value associated with the enum key (signed 32-bit)."
            },
            {
              "type": "object",
              "properties": {
                "value": {
                  "type": "integer", "minimum": -2147483648, "maximum": 2147483647,
                  "description": "Numeric value associated with the enum key (signed 32-bit)."
                },
                "description": { "type": "string", "description": "Optional explanation of the enum constant." }
              },
              "required": ["value"],
              "additionalProperties": false
            }
          ]
        }
      },
      "additionalProperties": false
    },

    "bitfield": {
      "type": "object",
      "description": "Defines the schema and constraints for bitfield elements.",
      "uniquePositions": true,
      "patternProperties": {
        "^[A-Za-z][A-Za-z0-9_]*$": {
          "type": "object",
          "description": "Defines a specific flag within the bitfield.",
          "properties": {
            "pos": {
              "type": "integer",
              "minimum": 0,
              "maximum": 63,
              "description": "Bit position of the flag within the bitfield."
            },
            "default": {
              "type": "boolean",
              "description": "Optional default value for the bitfield flag."
            },
            "description": {
              "type": "string",
              "description": "Optional explanation of the bitfield flag."
            }
          },
          "required": ["pos"],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },

    "struct": {
      "type": "object",
      "description": "Defines the schema and constraints for struct elements",
      "uniqueIds": true,
      "patternProperties": {
        "^[A-Za-z][A-Za-z0-9_]*$": {
          "$ref": "#/$defs/field"
        }
      },
      "additionalProperties": false
    },

    "union": {
      "type": "object",
      "description": "Defines the schema and constraints for union elements.",
      "uniqueIds": true,
      "patternProperties": {
        "^[A-Za-z][A-Za-z0-9_]*$": {
          "$ref": "#/$defs/field"
        }
      },
      "additionalProperties": false
    },

    "field": {
      "type": "object",
      "description": "Defines a single field inside a payload, struct, or union, including type, constraints and metadata.",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "u8", "u16", "u32", "u64",
            "i8", "i16", "i32", "i64",
            "fp32", "fp64",
            "boolean", "string", "blob",
            "array", "enum", "struct", "bitfield", "union"
          ],
          "description": "Data type of the field; determines allowed attributes and constraints."
        },
        "id": { "$ref": "#/$defs/types/id" },
        "description": {
          "type": "string",
          "description": "Optional free text describing the purpose of this field."
        },
        "decimals": {
          "type": "integer",
          "minimum": 0,
          "maximum": 15,
          "description": "Number of decimal places for floating-point numbers."
        },
        "unit": {
          "type": "string",
          "description": "Optional unit of measurement for numeric fields (e.g., 'kg', '°C')."
        },
        "deprecated": {
          "type": "boolean",
          "description": "Marks the field as deprecated; clients should avoid using it."
        }
      },
      "required": ["type", "id"],
      "additionalProperties": true,

      "allOf": [
        {
          "if": { "properties": { "type": { "const": "i8" } } },
          "then": {
            "properties": {
              "id": { "$ref": "#/$defs/types/id" },
              "type": { },
              "default": {
                "type": "integer", "minimum": -128, "maximum": 127,
                "description": "Optional default signed 8-bit integer value."
              },
              "description": { },
              "unit": { },
              "deprecated": { }
            },
            "additionalProperties": false
          }
        },
        {
          "if": { "properties": { "type": { "const": "u8" } } },
          "then": {
            "properties": {
              "id": { "$ref": "#/$defs/types/id" },
              "type": { },
              "default": {
                "type": "integer", "minimum": 0, "maximum": 255,
                "description": "Optional default unsigned 8-bit integer value."
              },
              "description": { },
              "unit": { },
              "deprecated": { }
            },
            "additionalProperties": false
          }
        },
        {
          "if": { "properties": { "type": { "const": "i16" } } },
          "then": {
            "properties": {
              "id": { "$ref": "#/$defs/types/id" },
              "type": { },
              "default": {
                "type": "integer", "minimum": -32768, "maximum": 32767,
                "description": "Optional default signed 16-bit integer value."
              },
              "description": { },
              "unit": { },
              "deprecated": { }
            },
            "additionalProperties": false
          }
        },
        {
          "if": { "properties": { "type": { "const": "u16" } } },
          "then": {
            "properties": {
              "id": { "$ref": "#/$defs/types/id" },
              "type": { },
              "default": {
                "type": "integer", "minimum": 0, "maximum": 65535,
                "description": "Optional default unsigned 16-bit integer value."
              },
              "description": { },
              "unit": { },
              "deprecated": { }
            },
            "additionalProperties": false
          }
        },
        {
          "if": { "properties": { "type": { "const": "i32" } } },
          "then": {
            "properties": {
              "id": { "$ref": "#/$defs/types/id" },
              "type": { },
              "default": {
                "type": "integer", "minimum": -2147483648, "maximum": 2147483647,
                "description": "Optional default signed 32-bit integer value."
              },
              "description": { },
              "unit": { },
              "deprecated": { }
            },
            "additionalProperties": false
          }
        },
        {
          "if": { "properties": { "type": { "const": "u32" } } },
          "then": {
            "properties": {
              "id": { "$ref": "#/$defs/types/id" },
              "type": { },
              "default": {
                "type": "integer", "minimum": 0, "maximum": 4294967295,
                "description": "Optional default unsigned 32-bit integer value."
              },
              "description": { },
              "unit": { },
              "deprecated": { }
            },
            "additionalProperties": false
          }
        },
        {
          "if": { "properties": { "type": { "const": "i64" } } },
          "then": {
            "properties": {
              "id": { "$ref": "#/$defs/types/id" },
              "type": { },
              "default": {
                "type": ["integer", "string"],
                "pattern": "^-?(0|[1-9][0-9]*)$",
                "description": "Optional default signed 64-bit integer. A plain JSON number works for values within +/-2^53; for exact values beyond that, give the integer as a JSON string (e.g. \"-9223372036854775808\")."
              },
              "description": { },
              "unit": { },
              "deprecated": { }
            },
            "int64Range": "i64",
            "additionalProperties": false
          }
        },
        {
          "if": { "properties": { "type": { "const": "u64" } } },
          "then": {
            "properties": {
              "id": { "$ref": "#/$defs/types/id" },
              "type": { },
              "default": {
                "type": ["integer", "string"],
                "pattern": "^(0|[1-9][0-9]*)$",
                "description": "Optional default unsigned 64-bit integer. A plain JSON number works for values within 2^53; for exact values beyond that, give the integer as a JSON string (e.g. \"18446744073709551615\")."
              },
              "description": { },
              "unit": { },
              "deprecated": { }
            },
            "int64Range": "u64",
            "additionalProperties": false
          }
        },
        {
          "if": { "properties": { "type": { "const": "fp32" } } },
          "then": {
            "properties": {
              "id": { "$ref": "#/$defs/types/id" },
              "type": { },
              "default": {
                "type": "number", "minimum": -3.4028235e+38, "maximum": 3.4028235e+38,
                "description": "Optional default floating-point value."
              },
              "description": { },
              "decimals": { },
              "unit": { },
              "deprecated": { }
            },
            "additionalProperties": false
          }
        },
        {
          "if": { "properties": { "type": { "const": "fp64" } } },
          "then": {
            "properties": {
              "id": { "$ref": "#/$defs/types/id" },
              "type": { },
              "default": {
                "type": "number", "minimum": -1.7976931348623157e+308, "maximum": 1.7976931348623157e+308,
                "description": "Optional default floating-point value."
              },
              "description": { },
              "decimals": { },
              "unit": { },
              "deprecated": { }
            },
            "additionalProperties": false
          }
        },
        {
          "if": { "properties": { "type": { "const": "boolean" } } },
          "then": {
            "properties": {
              "id": { "$ref": "#/$defs/types/id" },
              "type": { },
              "default": {
                "type": "boolean",
                "description": "Optional default boolean value."
              },
              "description": { },
              "deprecated": { }
            },
            "additionalProperties": false
          }
        },
        {
          "if": { "properties": { "type": { "const": "string" } } },
          "then": {
            "properties": {
              "id": { "$ref": "#/$defs/types/id" },
              "type": { },
              "maxlen": {
                "type": "integer",
                "minimum": 1,
                "maximum": 2147483647,
                "description": "Maximum string length. Optional, but required by targets that cannot allocate dynamically (see PLAN)."
              },
              "default": {
                "type": "string",
                "description": "Optional default string value; must comply with the maxlen constraint if defined.",
                "maxLength": { "$data": "1/maxlen" }
              },
              "description": { },
              "deprecated": { }
            },
            "additionalProperties": false
          }
        },
        {
          "if": { "properties": { "type": { "const": "blob" } } },
          "then": {
            "properties": {
              "id": { "$ref": "#/$defs/types/id" },
              "type": { },
              "maxlen": {
                "type": "integer",
                "minimum": 1,
                "maximum": 2147483647,
                "description": "Maximum blob length. Optional, but required by targets that cannot allocate dynamically (see PLAN)."
              },
              "default": {
                "type": "string",
                "pattern": "^[A-Za-z0-9+/\\s]+={0,2}$",
                "description": "Optional default binary data; use !!binary to specify base64-encoded data; must comply with the maxlen constraint if defined."
              },
              "description": { },
              "deprecated": { }
            },
            "blobDefaultLength": true,
            "additionalProperties": false
          }
        },

        {
          "if": { "properties": { "type": { "const": "enum" } } },
          "then": {
            "required": ["enum"],
            "properties": {
              "id": { "$ref": "#/$defs/types/id" },
              "type": { },
              "enum": {
                "oneOf": [
                  { "$ref": "#/$defs/enum" },
                  {
                    "type": "object",
                    "properties": {
                      "$ref": {
                        "type": "string",
                        "description": "Reference to a predefined enum in $defs."
                      }
                    },
                    "required": ["$ref"],
                    "additionalProperties": false
                  }
                ]
              },
              "default": {
                "type": "integer", "minimum": -2147483648, "maximum": 2147483647,
                "description": "Optional default value for the enum (signed 32-bit); must match one of the defined enum values."
              },
              "description": { },
              "deprecated": { }
            },
            "additionalProperties": false,
            "defaultMatchesEnum": true
          }
        },

        {
          "if": { "properties": { "type": { "const": "bitfield" } } },
          "then": {
            "properties": {
              "id": { "$ref": "#/$defs/types/id" },
              "type": { },
              "bits": {
                "oneOf": [
                  { "$ref": "#/$defs/bitfield" },
                  {
                    "type": "object",
                    "properties": {
                      "$ref": {
                        "type": "string",
                        "description": "Reference to a predefined bitfield in $defs."
                      }
                    },
                    "required": ["$ref"],
                    "additionalProperties": false
                  }
                ]
              },
              "description": { },
              "deprecated": { }
            },
            "required": ["bits"],
            "additionalProperties": false
          }
        },

        {
          "if": { "properties": { "type": { "const": "array" } } },
          "then": {
            "properties": {
              "id": { "$ref": "#/$defs/types/id" },
              "type": { },
              "items": { "$ref": "#/$defs/arrayItems" },
              "default": {
                "type": "array",
                "description": "Optional default array value; must match the defined item type and count.",
                "items": { },
                "maxItems": { "$data": "1/items/count" }
              },
              "description": { },
              "deprecated": { }
            },
            "required": ["items"],
            "additionalProperties": false,

            "allOf": [
              {
                "if": {
                  "properties": {
                    "items": {
                      "type": "object",
                      "properties": {
                        "type": { "const": "i8" }
                      }
                    }
                  }
                },
                "then": {
                  "properties": {
                    "default": {
                      "type": "array",
                      "items": { "type": "integer", "minimum": -128, "maximum": 127 }
                    }
                  }
                }
              },

              {
                "if": {
                  "properties": {
                    "items": {
                      "type": "object",
                      "properties": {
                        "type": { "const": "u8" }
                      }
                    }
                  }
                },
                "then": {
                  "properties": {
                    "default": {
                      "type": "array",
                      "items": { "type": "integer", "minimum": 0, "maximum": 255 }
                    }
                  }
                }
              },

              {
                "if": {
                  "properties": {
                    "items": {
                      "type": "object",
                      "properties": {
                        "type": { "const": "i16" }
                      }
                    }
                  }
                },
                "then": {
                  "properties": {
                    "default": {
                      "type": "array",
                      "items": { "type": "integer", "minimum": -32768, "maximum": 32767 }
                    }
                  }
                }
              },

              {
                "if": {
                  "properties": {
                    "items": {
                      "type": "object",
                      "properties": {
                        "type": { "const": "u16" }
                      }
                    }
                  }
                },
                "then": {
                  "properties": {
                    "default": {
                      "type": "array",
                      "items": { "type": "integer", "minimum": 0, "maximum": 65535 }
                    }
                  }
                }
              },

              {
                "if": {
                  "properties": {
                    "items": {
                      "type": "object",
                      "properties": {
                        "type": { "const": "i32" }
                      }
                    }
                  }
                },
                "then": {
                  "properties": {
                    "default": {
                      "type": "array",
                      "items": { "type": "integer", "minimum": -2147483648, "maximum": 2147483647 }
                    }
                  }
                }
              },

              {
                "if": {
                  "properties": {
                    "items": {
                      "type": "object",
                      "properties": {
                        "type": { "const": "u32" }
                      }
                    }
                  }
                },
                "then": {
                  "properties": {
                    "default": {
                      "type": "array",
                      "items": { "type": "integer", "minimum": 0, "maximum": 4294967295 }
                    }
                  }
                }
              },

              {
                "if": {
                  "properties": {
                    "items": {
                      "type": "object",
                      "properties": {
                        "type": { "const": "i64" }
                      }
                    }
                  }
                },
                "then": {
                  "properties": {
                    "default": {
                      "type": "array",
                      "items": { "type": "integer", "minimum": -9223372036854775808, "maximum": 9223372036854775807 }
                    }
                  }
                }
              },

              {
                "if": {
                  "properties": {
                    "items": {
                      "type": "object",
                      "properties": {
                        "type": { "const": "u64" }
                      }
                    }
                  }
                },
                "then": {
                  "properties": {
                    "default": {
                      "type": "array",
                      "items": { "type": "integer", "minimum": 0, "maximum": 18446744073709551615 }
                    }
                  }
                }
              },

              {
                "if": {
                  "properties": {
                    "items": {
                      "type": "object",
                      "properties": {
                        "type": { "const": "fp32" }
                      }
                    }
                  }
                },
                "then": {
                  "properties": {
                    "default": {
                      "type": "array",
                      "items": { "type": "number", "minimum": -3.4028235e+38, "maximum": 3.4028235e+38 }
                    }
                  }
                }
